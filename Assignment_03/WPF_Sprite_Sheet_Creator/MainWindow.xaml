<Window x:Class="WPF_Sprite_Sheet_Creator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sprite Sheet Generator"
        Height="500"
        Width="900">

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Click="New_Click"/>
                <MenuItem Header="_Open" Click="Open_Click"/>
                <Separator/>
                <MenuItem x:Name="SaveMenuItem" Header="_Save" Click="Save_Click" IsEnabled="False"/>
                <MenuItem Header="Save _As" Click="SaveAs_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo"/>
                <MenuItem Header="_Redo"/>
                <Separator/>
                <MenuItem Header="_Copy"/>
                <MenuItem Header="_Paste"/>
                <Separator/>
                <MenuItem Header="_Remove"/>
                <MenuItem Header="Remove _All"/>
            </MenuItem>
        </Menu>
        
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <!-- Project File -->
            <TextBlock x:Name="tbProjectFile"
                       Grid.Row="0"
                       Grid.Column="0"
                       Text="SpriteSheet.xml"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="Output Directory"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="tbOutputDir"
                     Grid.Row="1"
                     Grid.Column="1"
                     Margin="5"/>

            <Button Grid.Row="1"
                    Grid.Column="2"
                    Content="Browse..."
                    Margin="5"
                    Click="Browse_Click"/>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Filename (.png)"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="tbOutputFile"
                     Grid.Row="2"
                     Grid.Column="1"
                     Margin="5"
                     Text="SpriteSheet.png"/>

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Text="Columns"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="tbColumns"
                     Grid.Row="3"
                     Grid.Column="1"
                     Width="80"
                     Margin="5"
                     HorizontalAlignment="Left"
                     Text="1"/>

            <CheckBox x:Name="chkMetaData"
                      Grid.Row="3"
                      Grid.Column="2"
                      Content="Include metadata (.json)"
                      VerticalAlignment="Center"/>

            <GroupBox Grid.Row="4"
                      Grid.ColumnSpan="3"
                      Header="Images"
                      Margin="0,10,0,10">

                <ListBox x:Name="lbImages"
                         Height="150"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Orange"
                                    BorderThickness="2"
                                    Margin="5">
                                <Image Source="{Binding}"
                                       Width="100"
                                       Height="100"
                                       Stretch="Uniform"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>
            </GroupBox>

            <StackPanel Grid.Row="5"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Add"
                        Width="90"
                        Margin="5"
                        Click="Add_Click"/>

                <Button Content="Remove"
                        Width="90"
                        Margin="5"
                        Click="Remove_Click"/>

                <Button Content="Generate"
                        Width="100"
                        Margin="5"
                        Click="Generate_Click"/>
            </StackPanel>

        </Grid>
    </DockPanel>
</Window>