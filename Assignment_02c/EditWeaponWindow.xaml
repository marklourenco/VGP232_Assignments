<Window x:Class="Assignment_02c.EditWeaponWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Weapon"
        Height="450"
        Width="350"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Top">

            <TextBlock Text="Name" Margin="0,5,0,0"/>
            <TextBox x:Name="NameTextBox"/>

            <TextBlock Text="Type" Margin="0,10,0,0"/>
            <ComboBox x:Name="TypeComboBox">
                <ComboBoxItem>Sword</ComboBoxItem>
                <ComboBoxItem>Polearm</ComboBoxItem>
                <ComboBoxItem>Claymore</ComboBoxItem>
                <ComboBoxItem>Catalyst</ComboBoxItem>
                <ComboBoxItem>Bow</ComboBoxItem>
                <ComboBoxItem>None</ComboBoxItem>
            </ComboBox>

            <TextBlock Text="Image URL" Margin="0,10,0,0"/>
            <TextBox x:Name="ImageTextBox"/>

            <TextBlock Text="Rarity" Margin="0,10,0,0"/>
            <ComboBox x:Name="RarityComboBox">
                <ComboBoxItem>1</ComboBoxItem>
                <ComboBoxItem>2</ComboBoxItem>
                <ComboBoxItem>3</ComboBoxItem>
                <ComboBoxItem>4</ComboBoxItem>
                <ComboBoxItem>5</ComboBoxItem>
            </ComboBox>

            <TextBlock Text="Base Attack" Margin="0,10,0,0"/>
            <TextBox x:Name="BaseAttackTextBox"/>

            <TextBlock Text="Secondary Stat" Margin="0,10,0,0"/>
            <TextBox x:Name="SecondaryStatTextBox"/>

            <TextBlock Text="Passive" Margin="0,10,0,0"/>
            <TextBox x:Name="PassiveTextBox"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="GenerateButton"
                    Content="Generate"
                    Width="80"
                    HorizontalAlignment="Left"
                    Click="GenerateClicked"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,0,0">
                <Button x:Name="SubmitButton"
                        Content="Add"
                        Width="80"
                        Click="SubmitClicked"/>
                <Button Content="Cancel"
                        Width="80"
                        Margin="10,0,0,0"
                        Click="CancelClicked"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>