<Window x:Class="Assignment_02c.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weapons Editor"
        Height="500"
        Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Load"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="LoadClicked"/>

            <Button Content="Save"
                    Width="100"
                    Click="SaveClicked"/>
        </StackPanel>

        <GroupBox Header="Sort by:" Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="10,5">
                <RadioButton Content="Name"
                             Margin="0,0,15,0"
                             Checked="SortRadioSelected"/>

                <RadioButton Content="BaseAttack"
                             Margin="0,0,15,0"
                             Checked="SortRadioSelected"/>

                <RadioButton Content="Rarity"
                             Margin="0,0,15,0"
                             Checked="SortRadioSelected"/>

                <RadioButton Content="Type"
                             Checked="SortRadioSelected"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Show only type:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <ComboBox x:Name="FilterTypeComboBox"
                          Width="150"
                          SelectionChanged="FilterTypeOnlySelectionChanged"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter by name:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <TextBox x:Name="FilterNameTextBox"
                         Width="200"
                         TextChanged="FilterNameTextChanged"/>
            </StackPanel>

        </StackPanel>

        <Grid Grid.Row="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="WeaponListBox"
                     Grid.Column="0"
                     Margin="0,0,10,0"/>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Top">

                <Button Content="Add"
                        Width="100"
                        Margin="0,0,0,10"
                        Click="AddClicked"/>

                <Button Content="Edit"
                        Width="100"
                        Margin="0,0,0,10"
                        Click="EditClicked"/>

                <Button Content="Remove"
                        Width="100"
                        Click="RemoveClicked"/>

            </StackPanel>

        </Grid>

    </Grid>
</Window>